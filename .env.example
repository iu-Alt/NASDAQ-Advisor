# FRED API Key (免费注册: https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_fred_api_key_here

# Server酱 SendKey (微信推送: https://sct.ftqq.com/)
SERVER_CHAN_KEY=your_server_chan_key_here

# 邮件推送 (SMTP, 可选)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_TO=recipient@example.com

# GitHub Pages URL (部署后填写)
GITHUB_PAGES_URL=https://your-username.github.io/nasdaq-advisor/
